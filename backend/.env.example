# Backend Environment Variables Template
# Copy this to .env (not committed to git)

PORT=3000
NODE_ENV=development

# JWT Security
JWT_SECRET=your_super_secret_jwt_key_here

# Database Configuration (defaults to sqlite.db in the backend working directory)
DATABASE_URL=sqlite.db
# DATABASE_AUTH_TOKEN=get it from Turso

# Optional: LingQ API token for server-side dictionary hints (/vocab/hints) and import fallbacks
# LINGQ_TOKEN=

# Cloudinary — for user image and audio uploads (required in production)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
