# Backend Environment Variables Template
# Copy this to .env (not committed to git)

PORT=3000
NODE_ENV=development

# JWT Security
JWT_SECRET=your_super_secret_jwt_key_here

# Database Configuration (defaults to sqlite.db in the backend working directory)
DATABASE_URL=sqlite.db

# Optional: LingQ API token for server-side dictionary hints (/vocab/hints) and import fallbacks
# LINGQ_TOKEN=
# LINGQ_API_KEY=
